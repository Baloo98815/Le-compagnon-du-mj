{
  "name": "le-compagnon-du-mj-backend",
  "version": "1.0.0",
  "description": "Backend API pour Le Compagnon du MJ",
  "main": "src/server.js",
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning src/server.js",
    "dev": "nodemon --exec 'node --no-warnings=ExperimentalWarning' src/server.js",
    "test": "node --no-warnings=ExperimentalWarning ./node_modules/.bin/jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterFramework": []
  }
}
